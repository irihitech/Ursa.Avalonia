<UserControl
    x:Class="Ursa.Demo.Pages.ThemeVariantMapperDemo"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:u="https://irihi.tech/ursa"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:DataType="viewModels:ThemeVariantMapperDemoViewModel"
    xmlns:controls="clr-namespace:Ursa.Demo.Controls"
    xmlns:viewModels="clr-namespace:Ursa.Demo.ViewModels">
    <ScrollViewer Margin="16">
        <StackPanel Spacing="24">

            <controls:PageMetadataView DataContext="{Binding PageMetadata}"/>

            <TextBlock
                Margin="0,0,0,4"
                FontSize="22"
                FontWeight="Bold"
                Text="ThemeVariantMapper" />
            <TextBlock Text="ThemeVariantMapper listens to its parent's ActualThemeVariant and applies a user-defined mapping. The first matching entry in its Mappings collection is used; if no entry matches, the parent's theme is inherited unchanged." TextWrapping="Wrap" />

            <!--  Invert Light ↔ Dark  -->
            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Text="Example 1 — Invert Light ↔ Dark" />
            <TextBlock Text="The outer ThemeVariantScope forces Light. The ThemeVariantMapper inside it maps Light → Dark, so its children render in Dark mode even though the outer scope is Light." TextWrapping="Wrap" />

            <ThemeVariantScope RequestedThemeVariant="Light">
                <Border Theme="{DynamicResource CardBorder}">
                    <StackPanel Spacing="8">
                        <TextBlock FontStyle="Italic" Text="[Parent scope: Light]" />

                        <u:ThemeVariantMapper>
                            <u:ThemeVariantMapper.Mappings>
                                <u:ThemeVariantMapping Source="Light" Target="Dark" />
                                <u:ThemeVariantMapping Source="Dark" Target="Light" />
                            </u:ThemeVariantMapper.Mappings>

                            <Border Theme="{DynamicResource CardBorder}">
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="[ThemeVariantMapper: Light → Dark]" />
                                    <TextBlock Text="This content renders in Dark mode." />
                                    <Button Content="Dark-mode Button" />
                                </StackPanel>
                            </Border>
                        </u:ThemeVariantMapper>

                    </StackPanel>
                </Border>
            </ThemeVariantScope>

            <!--  Only map Dark, pass Light through  -->
            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Text="Example 2 — Map only Dark → Light, leave Light unchanged" />
            <TextBlock Text="The outer scope forces Dark. The mapper only has a Dark → Light mapping, so its child renders in Light mode. A sibling without the mapper stays in Dark mode." TextWrapping="Wrap" />

            <ThemeVariantScope RequestedThemeVariant="Dark">
                <Border Theme="{DynamicResource CardBorder}">
                    <StackPanel Spacing="12">
                        <TextBlock FontStyle="Italic" Text="[Parent scope: Dark]" />
                        <!--  Without mapper — stays Dark  -->
                        <Border Theme="{DynamicResource CardBorder}">
                            <TextBlock Text="No mapper — inherits Dark from parent." />
                        </Border>

                        <!--  With mapper Dark → Light  -->
                        <u:ThemeVariantMapper>
                            <u:ThemeVariantMapper.Mappings>
                                <u:ThemeVariantMapping Source="Dark" Target="Light" />
                            </u:ThemeVariantMapper.Mappings>
                            <Border Theme="{DynamicResource CardBorder}">
                                <StackPanel Spacing="6">
                                    <TextBlock FontWeight="SemiBold" Text="[ThemeVariantMapper: Dark → Light]" />
                                    <TextBlock Text="This content renders in Light mode inside a Dark parent." />
                                    <Button Content="Light-mode Button" />
                                </StackPanel>
                            </Border>
                        </u:ThemeVariantMapper>

                    </StackPanel>
                </Border>
            </ThemeVariantScope>


            <!--  Dynamic theme switching  -->
            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Text="Example 3 — Dynamic parent theme switching" />
            <TextBlock Text="Use the buttons below to change the parent scope's requested theme at runtime. The inner ThemeVariantMapper will react immediately." TextWrapping="Wrap" />
            <StackPanel>
                <TextBlock Text="Mapping rule: " />
                <TextBlock Text="Light -&gt; NightSky" />
                <TextBlock Text="Dark -&gt; Desert" />
            </StackPanel>

            <StackPanel Spacing="10">
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="Set parent to:" />
                    <Button Click="OnSetLight" Content="Light" />
                    <Button Click="OnSetDark" Content="Dark" />
                    <Button Click="OnSetDefault" Content="Default" />
                </StackPanel>

                <ThemeVariantScope x:Name="DynamicParentScope">
                    <Border Theme="{DynamicResource CardBorder}">
                        <StackPanel Spacing="12">
                            <TextBlock FontStyle="Italic">
                                <Run Text="[Parent scope — ActualThemeVariant: " />
                                <Run Text="{Binding #DynamicParentScope.ActualThemeVariant}" />
                                <Run Text="]" />
                            </TextBlock>

                            <u:ThemeVariantMapper x:Name="DynamicMapper">
                                <u:ThemeVariantMapper.Mappings>
                                    <u:ThemeVariantMapping Source="Light" Target="{x:Static semi:SemiTheme.NightSky}" />
                                    <u:ThemeVariantMapping Source="Dark" Target="{x:Static semi:SemiTheme.Desert}" />
                                </u:ThemeVariantMapper.Mappings>

                                <Border Theme="{DynamicResource CardBorder}">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontStyle="Italic" FontWeight="SemiBold">
                                            <Run Text="[ThemeVariantMapper — ActualThemeVariant: " />
                                            <Run Text="{Binding #DynamicMapper.ActualThemeVariant}" />
                                            <Run Text="]" />
                                        </TextBlock>
                                        <TextBlock Text="This content follows the mapped theme." />
                                        <Button Content="Mapped-theme Button" />
                                    </StackPanel>
                                </Border>
                            </u:ThemeVariantMapper>

                        </StackPanel>
                    </Border>
                </ThemeVariantScope>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

