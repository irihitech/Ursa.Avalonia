<UserControl
    x:Class="Ursa.Demo.Pages.DateTimePickerDemo"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Ursa.Demo.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:viewModels="clr-namespace:Ursa.Demo.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="viewModels:DateTimePickerDemoViewModel"
    mc:Ignorable="d">
    <StackPanel
        Margin="20"
        Spacing="20">
        <controls:PageMetadataView DataContext="{Binding PageMetadata}" />
        <StackPanel HorizontalAlignment="Left">
            <ToggleSwitch Name="needConfirm" Content="Need Confirm" />
            <u:Form>
                <TextBox
                    Name="formatBox"
                    Width="300"
                    u:FormItem.Label="DisplayFormat"
                    Text="yyyy年MM月dd日 HH时mm分ss秒" />
                <TextBox
                    Name="panelBox"
                    u:FormItem.Label="Panel"
                    Text="hh mm ss" />
                <TextBlock u:FormItem.Label="Selected" Text="{Binding #confirmPicker.SelectedDate}" />
                <u:DateTimePicker
                    Name="confirmPicker"
                    MinWidth="100"
                    u:FormItem.Label="Need Confirmation"
                    Classes="ClearButton"
                    DisplayFormat="{Binding #formatBox.Text}"
                    NeedConfirmation="{Binding #needConfirm.IsChecked}"
                    PanelFormat="{Binding #panelBox.Text}" />
                <u:DateTimePicker
                    MinWidth="100"
                    u:FormItem.NoLabel="True"
                    Classes="ClearButton"
                    DisplayFormat="{Binding #formatBox.Text}"
                    PanelFormat="{Binding #panelBox.Text}" />
            </u:Form>
        </StackPanel>
    </StackPanel>
</UserControl>
