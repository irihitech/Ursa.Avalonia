<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="OverlayDialogMaskBrush" ResourceKey="SemiColorOverlayBackground" />
    <StaticResource x:Key="DialogBackground" ResourceKey="SemiColorBackground2" />
    <StaticResource x:Key="DialogInfoIconForeground" ResourceKey="SemiColorPrimary" />
    <StaticResource x:Key="DialogQuestionIconForeground" ResourceKey="SemiColorPrimary" />
    <StaticResource x:Key="DialogExclamationIconForeground" ResourceKey="SemiYellow5" />
    <StaticResource x:Key="DialogSuccessIconForeground" ResourceKey="SemiColorSuccess" />
    <StaticResource x:Key="DialogWarningIconForeground" ResourceKey="SemiColorWarning" />
    <StaticResource x:Key="DialogErrorIconForeground" ResourceKey="SemiColorDanger" />
    <StaticResource x:Key="DialogBoxShadow" ResourceKey="SemiShadowElevated" />
</ResourceDictionary>